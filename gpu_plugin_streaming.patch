+// ============================================================================
+// Dense Weight Streaming (research prototype)
+// ============================================================================
+
+void network::enable_dense_weight_streaming(
+    std::shared_ptr<ov::intel_gpu::DenseWeightStreamingManager> mgr) {
+    m_dense_streaming = std::move(mgr);
+}
+
+bool network::has_dense_weight_streaming() const {
+    return m_dense_streaming && m_dense_streaming->is_initialized();
+}
+
+void network::try_init_dense_streaming() {
+    m_dense_streaming_checked = true;
+
+#ifdef OV_DENSE_WEIGHT_STREAMING_ENABLED
+    const char* path = std::getenv("OV_DENSE_STREAM_WEIGHTS");
+    if (!path || path[0] == '\0') return;
+
+    std::cout << "[DenseStreaming] Initializing from " << path << "\n";
+
+    ov::intel_gpu::DenseStreamingConfig config;
+    config.weights_file_path = path;
+    config.enable_timing = true;
+    config.read_from_env();
+
+    auto mgr = std::make_shared<ov::intel_gpu::DenseWeightStreamingManager>(
+        _engine, config);
+
+    if (!mgr->initialize()) {
+        std::cerr << "[DenseStreaming] Failed to initialize!\n";
+        return;
+    }
+
+    // Build weight mapping by scanning network primitives
+    if (!mgr->build_weight_mapping(this)) {
+        std::cerr << "[DenseStreaming] Failed to build weight mapping!\n";
+        return;
+    }
+
+    // Build execution order partition
+    if (!mgr->build_group_exec_order(this)) {
+        std::cerr << "[DenseStreaming] Failed to build group exec order!\n";
+        return;
+    }
+
+    m_dense_streaming = std::move(mgr);
+    std::cout << "[DenseStreaming] Initialized: " << m_dense_streaming->num_groups()
+              << " groups, streaming " << m_dense_streaming->num_streamed_layers()
+              << " layers, pinned head=" << m_dense_streaming->pin_head_layers()
+              << " tail=" << m_dense_streaming->pin_tail_layers() << "\n";
+#else
+    (void)this;
+#endif
+}
+
+void network::execute_impl_streamed(const std::vector<event::ptr>& events) {
+#ifdef OV_DENSE_WEIGHT_STREAMING_ENABLED
+    // ------------------------------------------------------------------
+    // Streamed execution: pre-decoder → HEAD → MIDDLE (streamed) → TAIL → post-decoder
+    // ------------------------------------------------------------------
+    // Instead of running all primitives sequentially, we partition them by
+    // decoder layer group and swap weight pointers between groups.
+
+    // Reset events for ALL primitives first (same as execute_impl)
+    for (auto& inst : _exec_order) {
+        inst->reset_events();
+        if (inst->is_input())
+            inst->add_dep_events(events);
+    }
+
+    // Phase 0: Pre-decoder (embeddings, vision encoder, etc.)
+    {
+        const auto& prims = m_dense_streaming->get_group_exec_primitives(
+            m_dense_streaming->exec_slot_pre_decoder());
+        for (auto* p : prims) {
+            auto* inst = static_cast<primitive_inst*>(p);
+            inst->prepare_primitive();
+            inst->execute();
+        }
+    }
+
+    // Phases 1-3: Streaming decode pipeline (HEAD → MIDDLE → TAIL)
+    auto compute_fn = [this](uint32_t group_idx, uint32_t /*first_layer*/,
+                              uint32_t /*num_layers*/) -> bool {
+        uint32_t slot;
+        if (group_idx == UINT32_MAX)
+            slot = m_dense_streaming->exec_slot_pinned_head();
+        else if (group_idx == UINT32_MAX - 1)
+            slot = m_dense_streaming->exec_slot_pinned_tail();
+        else
+            slot = group_idx;
+
+        const auto& prims = m_dense_streaming->get_group_exec_primitives(slot);
+        for (auto* p : prims) {
+            auto* inst = static_cast<primitive_inst*>(p);
+            inst->prepare_primitive();
+            inst->execute();
+        }
+        return true;
+    };
+
+    m_dense_streaming->execute_streamed_decode(
+        compute_fn, this, _stream.get());
+
+    // Phase 4: Post-decoder (final norm, lm_head, logits)
+    {
+        const auto& prims = m_dense_streaming->get_group_exec_primitives(
+            m_dense_streaming->exec_slot_post_decoder());
+        for (auto* p : prims) {
+            auto* inst = static_cast<primitive_inst*>(p);
+            inst->prepare_primitive();
+            inst->execute();
+        }
+    }
+
+    get_stream().flush();
+
+    // Reset all flags for the next execution
+    for (auto& inst : _exec_order) {
+        inst->reset_flags();
+    }
+#else
+    // Should never reach here if OV_DENSE_WEIGHT_STREAMING_ENABLED is off
+    execute_impl(events);
+#endif
+}
 
